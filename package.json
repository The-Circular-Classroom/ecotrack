    "@mui/material-nextjs": "^7.3.10",
    "@mui/x-data-grid": "^8.29.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.110.2",
    "@types/pdfkit": "^0.17.6",
    "next": "^16.2.10",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
