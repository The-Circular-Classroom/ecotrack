# Backend API specific environment variables
# Copy and rename to .env to use locally

# ============================================
# Database (Supabase PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres?schema=public

# ============================================
# AWS Cognito (Authentication)
# ============================================
COGNITO_USER_POOL_ID=ap-southeast-1_xxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# AWS Services
# ============================================
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=ecotrack-uploads-prod
SES_SENDER_EMAIL=noreply@ecotrack.com
SNS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:123456789:ecotrack-notifications

# ============================================
# Application
# ============================================
PORT=3000
NODE_ENV=development
