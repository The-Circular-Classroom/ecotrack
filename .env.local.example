# =============================================================================
# EcoTrack - Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# For Vercel deployments, configure these in the Vercel dashboard under
# Project Settings > Environment Variables.
#
# Preview deployments should use a separate staging Supabase project
# to isolate preview branch data from production.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# -----------------------------------------------------------------------------

# Supabase project URL - available in Supabase dashboard > Settings > API
# Public: exposed to the browser for client-side auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key - available in Supabase dashboard > Settings > API
# Public: used for client-side requests (respects RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key - available in Supabase dashboard > Settings > API
# SECRET: server-only, bypasses RLS - never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Database Connection (Required)
# -----------------------------------------------------------------------------

# Pooled connection via PgBouncer (port 6543)
# Used for all application queries in serverless environment
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Direct connection (port 5432)
# Used for Prisma migrations only (not pooled)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Email Service - Resend (Required)
# -----------------------------------------------------------------------------

# Resend API key - available at https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key

# Sender email address for transactional emails (optional, has default)
# Must be a verified domain in Resend
RESEND_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Vercel Environment Variable Configuration
# -----------------------------------------------------------------------------
# In the Vercel dashboard, configure the following environment variable sets:
#
# PRODUCTION environment:
#   - All variables above pointing to your production Supabase project
#   - Use Vercel's encrypted secrets (@database-url, @direct-url, etc.)
#
# PREVIEW environment:
#   - All variables above pointing to a STAGING Supabase project
#   - This ensures preview deployments are isolated from production data
#   - Create a separate Supabase project for staging/preview
#
# DEVELOPMENT environment:
#   - Same as .env.local (used when running `vercel dev`)
# -----------------------------------------------------------------------------
