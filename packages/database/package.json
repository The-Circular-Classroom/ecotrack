    "@prisma/adapter-pg": "^7.5.0"
  },
  "devDependencies": {
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
